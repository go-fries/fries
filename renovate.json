{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "separateMajorMinor": true,
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "constraints": {
    "go": "1.23.0"
  },
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchDepTypes": ["indirect"],
      "enabled": true
    },
    {
      "matchPackageNames": ["github.com/pingcap/..."],
      "groupName": "pingcap",
      "schedule": ["* * 1 * *"]
    },
    {
      "matchPackageNames": ["golang.org/x/**"],
      "groupName": "golang.org/x"
    }
  ]
}
